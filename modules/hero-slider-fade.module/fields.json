[
  {
    "name": "slides",
    "label": "Slides",
    "type": "group",
    "required": true,
    "occurrence": { "min": 2, "max": 10 },
    "children": [
      { "name": "headline", "label": "Título (HTML)", "type": "richtext", "required": true },
      { "name": "subheadline", "label": "Subtítulo", "type": "text" },

      {
        "name": "bg_image",
        "label": "Imagen fondo",
        "type": "image",
        "responsive": true,
        "resizable": true
      },
      {
        "name": "bg_align",
        "label": "Alineación vertical fondo",
        "type": "choice",
        "display": "select",
        "choices": [
          ["middle", "Middle"],
          ["bottom", "Bottom"]
        ],
        "default": "middle"
      },

      {
        "name": "fg_image",
        "label": "Imagen derecha (opcional)",
        "type": "image",
        "responsive": true,
        "resizable": true
      },

      {
        "name": "cta_text",
        "label": "CTA: texto",
        "type": "text",
        "default": "Conoce nuestros prototipos"
      },
      {
        "name": "cta_link",
        "label": "CTA: enlace",
        "type": "link"
      }
    ]
  },
  {
    "name": "settings",
    "label": "Configuración",
    "type": "group",
    "children": [
      {
        "name": "autoplay",
        "label": "Autoplay",
        "type": "boolean",
        "default": true
      },
      {
        "name": "interval_ms",
        "label": "Intervalo (ms)",
        "type": "number",
        "min": 2000,
        "max": 15000,
        "step": 500,
        "default": 6500
      }
    ]
  },
  {
    "name": "styles",
    "label": "Estilos",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "name": "layout",
        "label": "Layout",
        "type": "group",
        "children": [
          {
            "name": "content_width",
            "label": "Ancho contenedor (px)",
            "type": "number",
            "min": 900,
            "max": 1400,
            "step": 10,
            "default": 1200
          },
          {
            "name": "min_height",
            "label": "Altura mínima (px)",
            "type": "number",
            "min": 420,
            "max": 900,
            "step": 10,
            "default": 680
          }
        ]
      }
    ]
  }
]
          {
            "name": "icon_size",
            "label": "Tamaño del icono (px)",
            "type": "number",
            "min": 16,
            "max": 80,
            "step": 1,
            "default": 24
          },
          {
            "name": "gap",
            "label": "Separación icono/texto (px)",
            "type": "number",
            "min": 0,
            "max": 40,
            "step": 1,
            "default": 14
          },
          {
            "name": "item_gap",
            "label": "Separación entre items (px)",
            "type": "number",
            "min": 0,
            "max": 50,
            "step": 1,
            "default": 26
          }
        ]
      }
    ]
  }
